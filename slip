<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Slip Generator - Maryland Day 2026</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #f5f5f5;
}

/* Controls (hidden when printing) */
.controls {
  background: white;
  padding: 20px 24px;
  border-bottom: 3px solid #E21833;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.controls h1 {
  margin: 0 0 16px;
  color: #E21833;
  font-size: 22px;
}
.controls .row {
  display: flex;
  gap: 16px;
  align-items: flex-end;
  flex-wrap: wrap;
}
.controls label {
  display: block;
  font-size: 12px;
  color: #666;
  margin-bottom: 4px;
  font-weight: 600;
  text-transform: uppercase;
}
.controls input {
  width: 90px;
  padding: 9px 12px;
  border: 2px solid #ddd;
  border-radius: 8px;
  font-size: 16px;
}
.controls button {
  background: #E21833;
  color: white;
  border: none;
  padding: 11px 24px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
}
.controls button:hover { background: #c41529; }
.controls button.secondary {
  background: #444;
}
.controls .info {
  margin-left: auto;
  font-size: 13px;
  color: #666;
  max-width: 300px;
  line-height: 1.4;
}

/* Slips area */
.slips-page {
  width: 210mm;
  min-height: 270mm;
  margin: 20px auto;
  padding: 10mm;
  background: white;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-auto-rows: 42mm;
  gap: 3mm;
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.slip {
  border: 1.5px dashed #aaa;
  border-radius: 6px;
  padding: 4mm;
  display: flex;
  gap: 3mm;
  align-items: center;
  page-break-inside: avoid;
  break-inside: avoid;
  background: #fffef8;
}
.slip-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.slip-title {
  font-size: 8pt;
  font-weight: 700;
  color: #E21833;
  line-height: 1.2;
  margin-bottom: 1mm;
}
.slip-number {
  font-size: 24pt;
  font-weight: 900;
  color: #1a1a1a;
  line-height: 1;
  margin: 0.5mm 0 2mm;
  font-variant-numeric: tabular-nums;
}
.slip-company-line {
  font-size: 7pt;
  color: #666;
}
.slip-company-line .label {
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 1mm;
}
.slip-company-line .blank {
  border-bottom: 1px solid #999;
  display: block;
  height: 5mm;
}
.slip-qr {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 30mm;
}
.slip-qr canvas, .slip-qr img {
  width: 24mm !important;
  height: 24mm !important;
}
.slip-qr-label {
  font-size: 6pt;
  color: #444;
  margin-top: 1mm;
  text-align: center;
  line-height: 1.2;
  font-weight: 600;
}

.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #999;
}

/* Print styles */
@media print {
  body { background: white; }
  .controls { display: none; }
  .slips-page {
    box-shadow: none;
    margin: 0;
    page-break-after: always;
    break-after: page;
  }
  .slips-page:last-child {
    page-break-after: auto;
  }
  @page {
    size: letter;
    margin: 10mm;
  }
}
</style>
</head>
<body>

<div class="controls">
  <h1>🎫 Maryland Day Slip Generator</h1>
  <div class="row">
    <div>
      <label>Start #</label>
      <input type="number" id="startNum" value="1" min="1" max="999">
    </div>
    <div>
      <label>End #</label>
      <input type="number" id="endNum" value="100" min="1" max="999">
    </div>
    <button onclick="generate()">Generate Slips</button>
    <button class="secondary" onclick="window.print()">🖨️ Print / Save PDF</button>
    <div class="info">
      Tip: Use Chrome → Print → "Save as PDF". 12 slips per page on US Letter.
    </div>
  </div>
</div>

<div id="slipsContainer">
  <div class="empty-state">Loading slips...</div>
</div>

<script>
var WINNERS_URL = 'https://wgu12345.github.io/maryland-day-2026/winners.html';
var SLIPS_PER_PAGE = 12;

function pad(n) {
  var s = String(n);
  while (s.length < 3) s = '0' + s;
  return s;
}

function generate() {
  var startNum = parseInt(document.getElementById('startNum').value, 10);
  var endNum = parseInt(document.getElementById('endNum').value, 10);
  
  if (isNaN(startNum) || isNaN(endNum) || startNum > endNum || startNum < 1) {
    alert('Please enter valid start and end numbers (start ≤ end, start ≥ 1)');
    return;
  }
  
  if (endNum - startNum + 1 > 300) {
    if (!confirm('Generating ' + (endNum - startNum + 1) + ' slips. Continue?')) return;
  }
  
  var container = document.getElementById('slipsContainer');
  container.innerHTML = '';
  
  var totalSlips = endNum - startNum + 1;
  var totalPages = Math.ceil(totalSlips / SLIPS_PER_PAGE);
  
  for (var page = 0; page < totalPages; page++) {
    var pageDiv = document.createElement('div');
    pageDiv.className = 'slips-page';
    
    var pageStart = startNum + (page * SLIPS_PER_PAGE);
    var pageEnd = Math.min(pageStart + SLIPS_PER_PAGE - 1, endNum);
    
    for (var num = pageStart; num <= pageEnd; num++) {
      var slip = createSlip(num);
      pageDiv.appendChild(slip);
    }
    
    container.appendChild(pageDiv);
  }
  
  // Generate QR codes after slips are in DOM
  setTimeout(generateQRCodes, 50);
}

function createSlip(num) {
  var slip = document.createElement('div');
  slip.className = 'slip';
  slip.innerHTML = 
    '<div class="slip-left">' +
      '<div class="slip-title">🏆 Maryland Day<br>AI Challenge</div>' +
      '<div class="slip-number">#' + pad(num) + '</div>' +
      '<div class="slip-company-line">' +
        '<span class="label">Company Name:</span>' +
        '<span class="blank"></span>' +
      '</div>' +
    '</div>' +
    '<div class="slip-qr">' +
      '<div class="qr-target" data-num="' + num + '"></div>' +
      '<div class="slip-qr-label">Scan at<br>2:15 PM</div>' +
    '</div>';
  return slip;
}

function generateQRCodes() {
  var targets = document.querySelectorAll('.qr-target');
  targets.forEach(function(target) {
    target.innerHTML = '';
    new QRCode(target, {
      text: WINNERS_URL,
      width: 90,
      height: 90,
      colorDark: '#000000',
      colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.M
    });
  });
}

// Auto-generate on load
window.addEventListener('load', generate);
</script>

</body>
</html>
